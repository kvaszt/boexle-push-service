# Telekom IMAP (not needed server-side, each user has their own credentials)
# These are just for local testing with your own account

# Apple Push Notifications (APNs)
# Get these from Apple Developer Portal → Certificates → VoIP Services
APN_KEY_PATH=./certs/AuthKey_XXXXXXXX.p8
APN_KEY_ID=XXXXXXXXXX
APN_TEAM_ID=XXXXXXXXXX
APN_BUNDLE_ID=de.boexle.app
# TestFlight und App Store: true (Production-Gateway). Xcode-Debug oft Sandbox: false
APN_PRODUCTION=true

# API Server
PORT=3000
# Mindestens 32 Zeichen (HMAC für Access-JWT)
AUTH_TOKEN_SECRET=change-me-to-a-different-long-random-string-at-least-32-chars
# Hinter Reverse-Proxy (nginx/Caddy): 1 oder true, damit Rate-Limit die Client-IP sieht
TRUST_PROXY=
# Kommagetrennte Origins für Browser-Clients; leer lassen wenn nur native App
CORS_ORIGINS=
# HSTS von Helmet: bei TLS am Proxy auf false setzen (0/false), sonst weglassen
HELMET_HSTS=

# Database
DB_PATH=./boexle.db
# Encryption key for IMAP credentials (64 hex chars / 32 bytes)
# Generieren mit: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=hier-64-zufaellige-hex-zeichen

# Polling interval in minutes
POLL_INTERVAL_MINUTES=2
# seen_messages älter als N Tage werden beim Poll-Zyklus gelöscht (Default 90)
SEEN_MESSAGES_RETENTION_DAYS=90
